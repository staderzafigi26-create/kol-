# 服务端口，默认本地 3000
PORT=3000

# 本地开发可用 127.0.0.1；服务器部署请改成 0.0.0.0
HOST=127.0.0.1

# Apify 个人 API Token（必填，用于调用 Actor）
APIFY_API_TOKEN=

# =========================
# DingTalk 开放平台配置
# =========================

# 钉钉应用 AppKey（必填）
DINGTALK_APP_KEY=

# 钉钉应用 AppSecret（必填）
DINGTALK_APP_SECRET=

# 钉钉操作人 userId（必填，你提供的 ding...）
DINGTALK_OPERATOR_ID=

# 钉钉文档/多维表格容器 ID（可选，按你的 API 封装使用）
DINGTALK_DOC_ID=

# 页面展示用的钉钉文档链接（可选，不要提交真实链接）
DINGTALK_DOC_URL=

# 红人表 Table ID（必填，用于读取红人、平台、是否监控、关键词等）
DINGTALK_INFLUENCER_TABLE_ID=

# 视频表 Table ID（必填，用于写入命中帖子）
DINGTALK_VIDEO_TABLE_ID=

# 快照表 Table ID（可选，用于每次抓取留存与增量 delta 计算）
DINGTALK_SNAPSHOT_TABLE_ID=
